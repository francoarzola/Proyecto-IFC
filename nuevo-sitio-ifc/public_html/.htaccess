Options -Indexes
RewriteEngine On
# Activar forzado HTTPS solo con SSL operativo
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
RewriteRule ^includes/ - [F,L]
<FilesMatch "(?i)(^\.env|composer\.(json|lock)|package(-lock)?\.json|error_log|\.git|\.svn|\.ini|\.conf|\.sql|\.bak|\.old|\.zip|\.rar|\.7z|\.tar|\.gz|\.log)$">
Require all denied
</FilesMatch>
<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "geolocation=(),camera=(),microphone=()"
Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self' https://challenges.cloudflare.com; frame-src https://www.google.com https://www.google.cl;"
# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
ErrorDocument 404 /404.php
